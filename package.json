{
  "name": "krisha-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run typecheck",
    "dev": "npx netlify dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@netlify/blobs": "^9.1.2",
    "@netlify/functions": "^5.3.0",
    "cheerio": "^1.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
